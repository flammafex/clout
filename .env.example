# ============================================
# Clout - Environment Configuration
# ============================================
# Copy this file to .env and customize as needed
# All values shown are defaults

# ----------------------------------------
# Server Configuration
# ----------------------------------------

# Web server port
PORT=3000

# Require authentication for API endpoints
# Set to 'true' for production/public deployments
CLOUT_AUTH=false

# Node.js environment
NODE_ENV=production

# ----------------------------------------
# Production / Reverse Proxy
# ----------------------------------------

# Trust X-Forwarded-* headers from a reverse proxy (nginx, Caddy, etc.)
# Auto-enabled when NODE_ENV=production, but set explicitly for clarity.
# Required when running behind nginx/Caddy for correct client IP detection
# and rate limiting.
TRUST_PROXY=true

# Comma-separated list of allowed CORS origins.
# In production, localhost origins are rejected unless allow-listed.
# Example: https://clout.example.com
ALLOWED_ORIGINS=

# ----------------------------------------
# Data Storage Paths
# ----------------------------------------

# Clout data directory (identities, posts, media, config)
# Default: ~/.clout
CLOUT_DATA_DIR=/data

# ----------------------------------------
# External Services
# ----------------------------------------

# Witness - Threshold timestamping service
WITNESS_GATEWAY_URL=http://localhost:8080
WITNESS_NETWORK_ID=clout-testnet

# Freebird - Anonymous authorization (VOPRF)
FREEBIRD_ISSUER_URL=http://localhost:8081
FREEBIRD_VERIFIER_URL=http://localhost:8082

# Freebird Sybil resistance mode
# Options: none, pow, invitation
# - none: No proof required (development only)
# - pow: Proof-of-work puzzle (rate limits account creation)
# - invitation: Invitation code required (web-of-trust, recommended for production)
# Default in docker-compose.yaml is "invitation" — leave this commented to use that default,
# or uncomment to override.
# FREEBIRD_SYBIL_MODE=invitation

# HyperToken - P2P gossip relay
HYPERTOKEN_RELAY_URL=ws://localhost:3000

# ----------------------------------------
# Instance Metadata
# ----------------------------------------
# Publicly visible at GET /api/instance. All optional but recommended
# for production deployments so users can identify the operator.

# Display name of this instance (also sent to Freebird as community_name)
INSTANCE_NAME=Clout Instance

# Operator identity (your name or handle)
INSTANCE_OPERATOR=

# Short description shown in the instance info endpoint
INSTANCE_DESCRIPTION=An uncensorable social network instance

# PGP key (ASCII-armored) for encrypted contact
INSTANCE_PGP_KEY=

# Contact info (email, handle, etc.)
INSTANCE_CONTACT=

# ----------------------------------------
# Tor Configuration (Optional)
# ----------------------------------------

# Enable Tor routing for .onion services
TOR_ENABLED=false

# Tor SOCKS5 proxy URL
TOR_PROXY=socks5://localhost:9050

# ----------------------------------------
# Docker Compose Overrides
# ----------------------------------------

# Override ports when running with docker compose
CLOUT_PORT=3000
FREEBIRD_ISSUER_PORT=8081
FREEBIRD_VERIFIER_PORT=8082
WITNESS_GATEWAY_PORT=8080
HYPERTOKEN_RELAY_PORT=3001

# Freebird admin key (CHANGE IN PRODUCTION!)
# Must be at least 32 characters
# Admin UI accessible at http://localhost:8081/admin
FREEBIRD_ADMIN_KEY=dev-admin-key-change-in-production-32chars

# Instance owner's browser public key
# Required for admin features (backup/restore, Freebird link)
#
# BOOTSTRAP SEQUENCE (first run):
#   1. Leave this empty and start the stack: docker compose up --build
#   2. Open http://localhost:3000 — you'll be in visitor mode
#   3. Generate your first invitation: docker compose run --rm cli invite <your-key>
#      (Or use the Owner tab in the web UI after first redemption)
#   4. Click "Have an invite code?" and redeem the code — your browser identity is created
#   5. Go to Profile tab → copy your public key (64 hex chars)
#   6. Set it here: INSTANCE_OWNER_PUBKEY=<your-key>
#   7. Restart: docker compose restart clout
#
# Note: The first person to redeem an invitation on a fresh instance automatically
# becomes the owner. This env var lets you set it explicitly instead.
#
# INSTANCE_OWNER_PUBLIC_KEY is the authoritative env var name (read by owner-registry).
# INSTANCE_OWNER_PUBKEY is a fallback alias (read by settings route). Set either;
# if both are set, INSTANCE_OWNER_PUBLIC_KEY takes precedence.
INSTANCE_OWNER_PUBKEY=

# ----------------------------------------
# Debug
# ----------------------------------------

# Enable debug logging
DEBUG=false
